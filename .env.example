# Flask
SECRET_KEY=change-me-for-local-dev

# SQL Server
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=localhost,1433
DB_DATABASE=SecurityTraceDB
DB_USERNAME=sa
DB_PASSWORD=

# Trace pipeline SQL Server aliases
TRACE_SQL_HOST=localhost,1433
TRACE_SQL_USER=sa
TRACE_SQL_PASS=
TRACE_SQL_DB=SecurityTraceDB

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# LLM provider
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-flash
RAG_TOP_K=5
DETECTION_THRESHOLD=0.6

# Capture and scenario runtime
DUMPCAP_PATH=
LIVE_CAPTURE_DIR=data/live_captures
SCENARIO_DELAY=2.0
MAX_EVENTS_BUFFER=5000
ALERT_POLL_INTERVAL=3000
NETWORK_MONITOR_INTERVAL=5
